# Copy to .env and adjust. Used by server.js (and written by deploy.sh).

PORT=3000
NODE_ENV=development

# Public site URL (no trailing slash). API is same origin at /api
FRONTEND_URL=http://localhost:5500

# Hostnames rewritten when fixing extracted HTML (comma-separated)
FRONTEND_HOSTS=localhost

# Same-origin /api proxy (recommended in production):
COOKIE_SAME_SITE=lax
# COOKIE_DOMAIN=

# Cross-subdomain API only — also set public/config.js API_URL:
# COOKIE_SAME_SITE=none
# COOKIE_DOMAIN=.example.com

# Absolute path to uploaded files (default: ../creative next to mainFile)
# STORAGE_DIR=/var/www/creative/uploads/files

FM_USERNAME=reachable
FM_PASSWORD=Reachable@2025#
SESSION_SECRET=change-me-to-a-long-random-string
